<?xml version="1.0" encoding="UTF-8"?>
<beans
  xmlns=
    "http://www.springframework.org/schema/beans"
  xmlns:xsi=
    "http://www.w3.org/2001/XMLSchema-instance"
  xmlns:context=
    "http://www.springframework.org/schema/context"
  xmlns:tx=
    "http://www.springframework.org/schema/tx"
  xsi:schemaLocation="
    http://www.springframework.org/schema/beans
    http://www.springframework.org/schema/beans/spring-beans-3.2.xsd
    http://www.springframework.org/schema/context
    http://www.springframework.org/schema/context/spring-context-3.2.xsd
    http://www.springframework.org/schema/tx
    http://www.springframework.org/schema/tx/spring-tx-3.2.xsd">

  <!--
    Trade Ledger Service
    Root Application Context

    Contains: datasource, transaction manager,
    DAO beans, service beans.

    All wiring is explicit XML - no component
    scanning, no annotation-based config.
    This is how we've always done it.

    Author: Platform Engineering
    Date:   2012-03-14
  -->

  <!-- Load JDBC properties -->
  <bean id="propertyConfigurer"
    class="org.springframework.beans.factory.config.PropertyPlaceholderConfigurer">
    <property name="location"
      value="/WEB-INF/jdbc.properties" />
  </bean>

  <!--
    Sybase ASE DataSource via Commons DBCP.
    Uses jConnect 7 JDBC driver.

    WARNING: Do not change the driver class
    without testing on all environments first.
    jConnect 16 has a different package name
    and broke things in staging (FI-4201).
  -->
  <bean id="dataSource"
    class="org.apache.commons.dbcp.BasicDataSource"
    destroy-method="close">
    <property name="driverClassName"
      value="${jdbc.driver}" />
    <property name="url"
      value="${jdbc.url}" />
    <property name="username"
      value="${jdbc.username}" />
    <property name="password"
      value="${jdbc.password}" />
    <property name="initialSize"
      value="${pool.initialSize}" />
    <property name="maxActive"
      value="${pool.maxActive}" />
    <property name="maxIdle"
      value="${pool.maxIdle}" />
    <property name="minIdle"
      value="${pool.minIdle}" />
    <property name="maxWait"
      value="${pool.maxWait}" />
    <property name="validationQuery"
      value="${pool.validationQuery}" />
    <property name="testOnBorrow"
      value="${pool.testOnBorrow}" />
    <property name="testWhileIdle"
      value="${pool.testWhileIdle}" />
  </bean>

  <!-- JdbcTemplate - shared across DAOs -->
  <bean id="jdbcTemplate"
    class="org.springframework.jdbc.core.JdbcTemplate">
    <property name="dataSource"
      ref="dataSource" />
  </bean>

  <!--
    Transaction manager.
    Manual transaction demarcation in
    service layer via TransactionTemplate.
  -->
  <bean id="transactionManager"
    class="org.springframework.jdbc.datasource.DataSourceTransactionManager">
    <property name="dataSource"
      ref="dataSource" />
  </bean>

  <bean id="transactionTemplate"
    class="org.springframework.transaction.support.TransactionTemplate">
    <property name="transactionManager"
      ref="transactionManager" />
  </bean>

  <!-- ================================= -->
  <!-- DAO Beans (setter injection)      -->
  <!-- ================================= -->

  <bean id="tradeDao"
    class="com.ubs.ledger.dao.TradeDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <bean id="counterpartyDao"
    class="com.ubs.ledger.dao.CounterpartyDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <bean id="instrumentDao"
    class="com.ubs.ledger.dao.InstrumentDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <bean id="traderDao"
    class="com.ubs.ledger.dao.TraderDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <bean id="settlementDao"
    class="com.ubs.ledger.dao.SettlementDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <bean id="tradeAuditDao"
    class="com.ubs.ledger.dao.TradeAuditDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <bean id="reportDao"
    class="com.ubs.ledger.dao.ReportDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <!-- ================================= -->
  <!-- Service Beans                     -->
  <!-- ================================= -->

  <bean id="tradeService"
    class="com.ubs.ledger.service.TradeService">
    <property name="tradeDao"
      ref="tradeDao" />
    <property name="tradeAuditDao"
      ref="tradeAuditDao" />
    <property name="settlementDao"
      ref="settlementDao" />
    <property name="transactionTemplate"
      ref="transactionTemplate" />
  </bean>

  <bean id="reportService"
    class="com.ubs.ledger.service.ReportService">
    <property name="reportDao"
      ref="reportDao" />
  </bean>

  <bean id="referenceDataService"
    class="com.ubs.ledger.service.ReferenceDataService">
    <property name="counterpartyDao"
      ref="counterpartyDao" />
    <property name="instrumentDao"
      ref="instrumentDao" />
    <property name="traderDao"
      ref="traderDao" />
  </bean>

</beans>
