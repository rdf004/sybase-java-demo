<?xml version="1.0" encoding="UTF-8"?>
<beans
  xmlns=
    "http://www.springframework.org/schema/beans"
  xmlns:xsi=
    "http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.springframework.org/schema/beans
    http://www.springframework.org/schema/beans/spring-beans-3.2.xsd">

  <!--
    Test application context.
    Points to the same Sybase ASE instance
    as production for integration tests.

    NOTE: Yes, we test against real Sybase.
    There is no mock or embedded alternative
    for Sybase ASE. This is intentional -
    these tests exist to verify stored proc
    behavior after migration.
  -->

  <bean id="dataSource"
    class="org.apache.commons.dbcp.BasicDataSource"
    destroy-method="close">
    <property name="driverClassName"
      value=
        "com.sybase.jdbc4.jdbc.SybDriver" />
    <property name="url"
      value=
  "jdbc:sybase:Tds:10.2.48.101:5000/ubs_ledger" />
    <property name="username"
      value="sa" />
    <property name="password"
      value="sybase_password" />
    <property name="maxActive"
      value="5" />
  </bean>

  <bean id="jdbcTemplate"
    class="org.springframework.jdbc.core.JdbcTemplate">
    <property name="dataSource"
      ref="dataSource" />
  </bean>

  <bean id="tradeDao"
    class="com.ubs.ledger.dao.TradeDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <bean id="reportDao"
    class="com.ubs.ledger.dao.ReportDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <bean id="tradeAuditDao"
    class="com.ubs.ledger.dao.TradeAuditDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

  <bean id="settlementDao"
    class="com.ubs.ledger.dao.SettlementDao">
    <property name="jdbcTemplate"
      ref="jdbcTemplate" />
  </bean>

</beans>
